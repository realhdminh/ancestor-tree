# ─────────────────────────────────────────────────────────────────────────────
# AncestorTree — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
#
#   cp .env.local.example .env.local
#
# .env.local is gitignored and will NOT be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project → Settings → API
# For local dev, run `pnpm local:setup` to auto-generate these values.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-side only (API routes, admin operations)
# ⚠️  Never expose this to the browser (no NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database password — dùng cho direct PostgreSQL connection, Supabase CLI, tools như TablePlus
# Get from: Supabase Dashboard → Project → Settings → Database → Database password
# Connection string: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_DB_PASSWORD=your-database-password

# ── Site Identity ────────────────────────────────────────────────────────────
# Customize these to rebrand for a different clan/family
NEXT_PUBLIC_CLAN_NAME=Họ Đặng
NEXT_PUBLIC_CLAN_LOCATION=làng Kỷ Các
NEXT_PUBLIC_APP_TITLE=Gia Phả Điện Tử
NEXT_PUBLIC_APP_TAGLINE=Gìn giữ tinh hoa - Tiếp bước cha ông
NEXT_PUBLIC_APP_DESCRIPTION=Phần mềm quản lý gia phả điện tử cho Họ Đặng làng Kỷ Các. Lưu trữ thông tin dòng họ, cây gia phả, lịch giỗ chạp.
NEXT_PUBLIC_CLAN_AVATAR_LETTER=Đ

# ── Local Development ────────────────────────────────────────────────────────
# Set to true when using `pnpm local:setup` (Supabase CLI + Docker)
# Auto-set by scripts/local-setup.mjs — do not set manually for cloud.
NEXT_PUBLIC_LOCAL_DEV=false

# ── Desktop / Electron Mode ──────────────────────────────────────────────────
# Set to true when running inside the Electron desktop app (Sprint 9).
# Uses SQLite via /api/desktop-db instead of Supabase.
NEXT_PUBLIC_DESKTOP_MODE=false

# Server-side desktop flag (used by API routes that check both vars)
DESKTOP_MODE=false

# Custom data directory for SQLite DB and media files (optional)
# Default: ~/AncestorTree
# DESKTOP_DATA_DIR=/path/to/custom/data/dir

# Custom migrations directory for SQLite schema (optional)
# Default: auto-detected from app bundle
# MIGRATIONS_DIR=/path/to/migrations
